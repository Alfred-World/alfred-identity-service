# ─────────────────────────────────────────────────────────────────────────────
# Alfred Identity Service — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
APP_HOSTNAME=localhost
APP_PORT=8100
APP_SECRET_KEY=<CHANGE_ME>

# ── Database ──────────────────────────────────────────────────────────────────
# Provider (only PostgreSQL is supported)
DB_PROVIDER=PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=alfred_identity
DB_USER=postgres
DB_PASSWORD=change_me

# EF Core diagnostics — enable only in Development
ENABLE_SENSITIVE_DATA_LOGGING=false
ENABLE_DETAILED_ERRORS=false

# ── Cache ─────────────────────────────────────────────────────────────────────
# Options: InMemory (default) | Redis
CACHE_PROVIDER=InMemory

# ── Redis ─────────────────────────────────────────────────────────────────────
# Required when CACHE_PROVIDER=Redis or for the email notification queue
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me

# Redis stream for publishing identity user replication events to alfred-core
IDENTITY_USER_STREAM_KEY=identity:user-events

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (Identity Web + Gateway)
CORS_ALLOWED_ORIGINS=https://gateway.test


# ── SSO Cookie ────────────────────────────────────────────────────────────────
SSO_COOKIE_DOMAIN=gateway.test

# ── JWT / OpenIddict ──────────────────────────────────────────────────────────
# All JWT config is consolidated in AppConfiguration.cs — no more appsettings.json
# JWT_ISSUER MUST match AUTH_VALID_ISSUER on the gateway — mismatch = 401 on all API calls
# [Required] Public gateway URL
JWT_ISSUER=https://gateway.test
# [Required] Must match AUTH_AUDIENCE on gateway
JWT_AUDIENCE=alfred-ecosystem
# [Optional] Default: 900 (15 min)
# JWT__ACCESSTOKENLIFETIMESECONDS=900
# [Optional] Default: 604800 (7 days)
# JWT__REFRESHTOKENLIFETIMESECONDS=604800

# ── [Required] URL Configuration ──────────────────────────────────────────────
# Supports both formats: URLS_GATEWAY (preferred) or Urls__Gateway (legacy docker-compose)
URLS_GATEWAY=https://gateway.test
URLS_SSO_WEB=https://sso.test
URLS_CORE_WEB=https://core.test
URLS_IDENTITY_WEB=https://sso.test

# ── Google OAuth2 (optional) ──────────────────────────────────────────────────
# When both values are set, Google Sign-In is enabled automatically
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── mTLS (optional) ───────────────────────────────────────────────────────────
# Only required when running behind a service mesh with mutual TLS
MTLS_ENABLED=false
MTLS_SERVER_CERT_PATH=
MTLS_SERVER_CERT_PASSWORD=
MTLS_CA_CERT_PATH=
MTLS_HTTPS_PORT=8101
MTLS_ALLOW_HTTP=true
MTLS_HTTP_PORT=8100
